#!/usr/bin/env python3
"""Pre-commit hook: local validation + BOM stripping.

This hook ensures that:
1. UTF-8 BOM is stripped from staged files (PowerShell cleanup)
2. L1a validation (general format rules) passes
3. L1b validation (English-only language policy) passes
4. L2 validation (section structure per file type) passes
5. L3 validation (link integrity) passes
6. L4 validation (culture completeness) passes
7. .validation-stamp is written with current tree hash

All validations must pass before commit. CI will verify the stamp gate is present.
"""
from __future__ import annotations

import subprocess
import sys
from pathlib import Path

UTF8_BOM = b"\xef\xbb\xbf"

# Branch classification and scope rules live in tests/branch_scope.py
# (single source of truth, also imported by future CI mirror).
HOOK_DIR = Path(__file__).resolve().parent
REPO_ROOT = HOOK_DIR.parent
sys.path.insert(0, str(REPO_ROOT / "tests"))

from branch_scope import (
    SAFE_PATTERNS,
    WORLD_SLUGS,
    check_scope,
    classify_branch,
    culture_scope,
)


def run_git(*args: str) -> str:
    """Run git command and return output."""
    result = subprocess.run(
        ["git", *args],
        capture_output=True,
        text=True,
        check=False,
    )
    return result.stdout.strip()


def strip_bom_from_staged_files() -> list[str]:
    """Strip UTF-8 BOM from any staged text file that has one.

    PowerShell Set-Content writes BOM regardless of .editorconfig. Stripping
    at commit time keeps the repository clean without requiring each tool/shell
    to be configured correctly.

    Returns a list of file paths that were fixed.
    """
    staged = run_git("diff", "--cached", "--name-only")
    fixed = []
    for rel in staged.splitlines():
        path = Path(rel)
        if not path.exists() or path.suffix not in {".md", ".txt", ".py", ".sh", ".json"}:
            continue
        raw = path.read_bytes()
        if raw.startswith(UTF8_BOM):
            path.write_bytes(raw[3:])
            subprocess.run(["git", "add", rel], check=False)
            fixed.append(rel)
    return fixed


def main() -> int:
    # Strip BOM from staged files before any other checks.
    # Transparent fix for PowerShell Set-Content BOM injection.
    fixed = strip_bom_from_staged_files()
    if fixed:
        for f in fixed:
            print(f"  (stripped UTF-8 BOM from {f})")

    # Guard: classify branch and enforce scope.
    current_branch = run_git("rev-parse", "--abbrev-ref", "HEAD")
    branch_kind = classify_branch(current_branch)

    if branch_kind == "main":
        print(">>> ERROR: Direct commits to main are forbidden")
        print("")
        print("Create a feature branch first:")
        print("  git checkout -b culture/<country>     # culture content")
        print("  git checkout -b governance/<name>     # validators, hooks, workflows")
        print("  git checkout -b chore/<name>          # general tooling / docs")
        print("  git checkout -b fix/<name>            # corrections (non-culture, non-gate)")
        print("")
        return 1

    all_staged = run_git("diff", "--cached", "--name-only", "--diff-filter=ACMRT").splitlines()
    ok, unsafe_files = check_scope(branch_kind, all_staged, current_branch)
    if not ok:
        if branch_kind == "culture":
            prefix = culture_scope(current_branch)
            if prefix is None:
                print(">>> ERROR: Unknown culture slug")
                print("")
                print(f"  Branch:  {current_branch}")
                print( "  Rule:    culture/<slug> must resolve to a country, region, or integration target")
                print( "  Country: culture/<country>     -> regions/<region>/<country>/**")
                print( "  Region:  culture/<region>      -> regions/<region>/**")
                print( "  World:   culture/release -> regions/**")
            else:
                print(f">>> ERROR: Culture branch out of scope (allowed: {prefix}**)")
                print("")
                print("Unsafe files detected (split to a separate branch):")
                for f in unsafe_files:
                    print(f"  x {f}")
                print("")
                print(f"  Branch:  {current_branch}")
                print(f"  Allowed: {prefix}** + " + ", ".join(sorted(SAFE_PATTERNS)))
                print( "  Rule:    culture/<slug> may only touch its own slug's subtree")
                print( "  Wider:   use culture/<region> or culture/release for cross-cutting work")
        elif branch_kind == "governance":
            print(">>> ERROR: Governance branch out of scope")
            print("")
            print("Non-governance files detected (move to a different branch):")
            for f in unsafe_files:
                print(f"  x {f}")
            print("")
            print(f"  Branch:  {current_branch}")
            print( "  Rule:    governance/<name> may only touch governance paths")
            print( "  Allowed: .githooks/**, .github/workflows/**, tests/branch_scope.py,")
            print( "           tests/test_*.py, tests/validate_*.py, scripts/validate*,")
            print( "           data/hofstede_{denylist,keywords,scores,bag_loader}.*")
            print( "  Other:   use chore/<name> for non-governance tooling/docs")
        elif branch_kind == "fork":
            print(">>> ERROR: Fork branch out of scope")
            print("")
            print("Non-culture files detected (a fork/* branch is culture content only):")
            for f in unsafe_files:
                print(f"  x {f}")
            print("")
            print(f"  Branch:  {current_branch}")
            print( "  Rule:    fork/<name> may only touch regions/** + safe metadata")
            print( "  Reason:  the external-contributor lane is confined to culture")
            print( "           content -- no engine, scripts, validators, workflows,")
            print( "           or governance data")
        else:
            print(">>> ERROR: Non-culture/non-governance branch out of scope")
            print("")
            print("Restricted files detected (move to the right branch kind):")
            for f in unsafe_files:
                print(f"  x {f}")
            print("")
            print(f"  Branch:  {current_branch}")
            print( "  Rule:    chore/*, fix/*, feat/* must not modify regions/** or governance paths")
            print( "  Culture: git checkout -b culture/<country>     for regions/** changes")
            print( "  Govern:  git checkout -b governance/<name>     for validators/hooks/workflows")
        print("")
        return 1

    # Run validation orchestrator (L1a → L1b → L2 → L4 → L4h) on staged
    # content files only. This matches CI's scope (regions/*.md changed in
    # the diff) so legacy files in untouched paths don't block unrelated
    # commits while migrations are in flight.
    staged = run_git("diff", "--cached", "--name-only", "--diff-filter=ACMRT")
    staged_content = [
        f for f in staged.splitlines()
        if f.endswith(".md") and f.startswith("regions/")
    ]

    if staged_content:
        result = subprocess.run(
            [sys.executable, "scripts/validate.py", *staged_content],
            capture_output=True,
            text=True,
            check=False,
        )
        if result.returncode != 0:
            print(f">>> VALIDATION FAILED")
            print("")
            print(result.stdout.strip())
            print("")
            return 1

        # Local parity for link integrity: run the same in-repo link test on
        # the staged markdown scope before push.
        result = subprocess.run(
            [
                sys.executable,
                "-m",
                "pytest",
                "-q",
                "tests/test_links.py",
                "--khai-roots=engine",
                f"--khai-files={' '.join(staged_content)}",
            ],
            capture_output=True,
            text=True,
            check=False,
        )
        if result.returncode != 0:
            print(">>> LINK VALIDATION FAILED")
            print("")
            if result.stdout.strip():
                print(result.stdout.strip())
            if result.stderr.strip():
                print(result.stderr.strip())
            print("")
            return 1

    # On culture and fork branches: also run Hofstede validation.
    # Culture content must maintain declared dimension alignment; a fork/*
    # branch carries culture content too, so it is held to the same gates.
    if branch_kind in ("culture", "fork"):
        # Language gate: the staged country's README-declared language must
        # be registered in data/language_policy.yaml ("already working")
        # before its culture content can land. The orchestrator above only
        # does per-file detection, which silently falls back to English for
        # an unregistered language -- this check catches it loudly.
        if staged_content:
            result = subprocess.run(
                [
                    sys.executable,
                    "tests/validate_language.py",
                    "--check-readmes-only",
                    *staged_content,
                ],
                capture_output=True,
                text=True,
                check=False,
            )
            if result.returncode != 0:
                print(">>> LANGUAGE REGISTRY CHECK FAILED")
                print("")
                if result.stdout.strip():
                    print(result.stdout.strip())
                if result.stderr.strip():
                    print(result.stderr.strip())
                print("")
                return 1

            # Language unlock gate: the staged country's language in
            # data/countries.json must be unlocked (its ISO code maps,
            # via data/language_policy.yaml iso_map, onto a registered
            # lingua name). This is the data-keyed pre-flight -- culture
            # work must not start on a country whose language the
            # validator cannot actually check.
            result = subprocess.run(
                [
                    sys.executable,
                    "tests/validate_language.py",
                    "--check-unlocked",
                    *staged_content,
                ],
                capture_output=True,
                text=True,
                check=False,
            )
            if result.returncode != 0:
                print(">>> LANGUAGE UNLOCK CHECK FAILED")
                print("")
                if result.stdout.strip():
                    print(result.stdout.strip())
                if result.stderr.strip():
                    print(result.stderr.strip())
                print("")
                return 1

        culture_files = [
            f for f in staged_content
            if "culture_" in f
        ]
        if culture_files:
            result = subprocess.run(
                [sys.executable, "tests/validate_hofstede_derived.py", *culture_files],
                capture_output=True,
                text=True,
                check=False,
            )
            if result.returncode != 0:
                print(f">>> HOFSTEDE VALIDATION FAILED")
                print("")
                print(result.stdout.strip())
                print("")
                return 1

            # Hofstede reference check: declared scores must match
            # data/hofstede_scores.json within +/-5 or carry a deviation
            # justification in hofstede_decisions.md. Closes the
            # "LLM invents plausible scores" vector that the gap-based
            # derived check doesn't catch (an invented score would still
            # have an internally-consistent keyword profile).
            result = subprocess.run(
                [sys.executable, "tests/validate_hofstede_reference.py", *culture_files],
                capture_output=True,
                text=True,
                check=False,
            )
            if result.returncode != 0:
                print(">>> HOFSTEDE REFERENCE CHECK FAILED")
                print("")
                print(result.stdout.strip())
                print("")
                return 1

    # On any branch: validate any staged Hofstede bag YAML.
    # Catches schema, denylist coherence, and within-country collision issues
    # before push. Cross-country checks happen in CI via the pytest suite.
    bag_files = [
        f for f in all_staged
        if f.startswith("regions/")
        and (f.endswith("/hofstede_bag.yaml") or "/hofstede_bag_" in f)
        and f.endswith(".yaml")
    ]
    if bag_files:
        result = subprocess.run(
            [sys.executable, "tests/validate_country_bag.py", *bag_files],
            capture_output=True,
            text=True,
            check=False,
        )
        if result.returncode != 0:
            print(">>> BAG VALIDATION FAILED")
            print("")
            print(result.stdout.strip())
            if result.stderr.strip():
                print(result.stderr.strip())
            print("")
            return 1

    # Write validation stamp: hash of the content tree, excluding the stamp file itself
    # (removing stamp from index avoids a circular hash dependency).
    subprocess.run(["git", "rm", "--cached", "--ignore-unmatch", ".validation-stamp"],
                   capture_output=True, check=False)
    tree_hash = run_git("write-tree")
    Path(".validation-stamp").write_text(tree_hash + "\n", encoding="utf-8")
    subprocess.run(["git", "add", ".validation-stamp"], check=False)
    print(f"+ Validation stamp written ({tree_hash[:12]})")

    return 0


if __name__ == "__main__":
    sys.exit(main())
