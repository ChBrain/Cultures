#!/usr/bin/env python3
"""Pre-commit hook: L0-L4 validation + BOM stripping.

This hook ensures that:
1. UTF-8 BOM is stripped from staged files (PowerShell cleanup)
2. L1a validation (general format rules) passes
3. L1b validation (English-only language policy) passes
4. L2 validation (section structure per file type) passes
5. L3 validation (link integrity) passes
6. L4 validation (culture completeness) passes
7. .validation-stamp is written with current tree hash

All validations must pass before commit. CI will verify the stamp gate is present.
"""
from __future__ import annotations

import subprocess
import sys
from pathlib import Path

UTF8_BOM = b"\xef\xbb\xbf"

# Branch classification and scope rules live in tests/branch_scope.py
# (single source of truth, also imported by future CI mirror).
HOOK_DIR = Path(__file__).resolve().parent
REPO_ROOT = HOOK_DIR.parent
sys.path.insert(0, str(REPO_ROOT / "tests"))

from branch_scope import (
    SAFE_PATTERNS,
    check_scope,
    classify_branch,
)


def run_git(*args: str) -> str:
    """Run git command and return output."""
    result = subprocess.run(
        ["git", *args],
        capture_output=True,
        text=True,
        check=False,
    )
    return result.stdout.strip()


def strip_bom_from_staged_files() -> list[str]:
    """Strip UTF-8 BOM from any staged text file that has one.

    PowerShell Set-Content writes BOM regardless of .editorconfig. Stripping
    at commit time keeps the repository clean without requiring each tool/shell
    to be configured correctly.

    Returns a list of file paths that were fixed.
    """
    staged = run_git("diff", "--cached", "--name-only")
    fixed = []
    for rel in staged.splitlines():
        path = Path(rel)
        if not path.exists() or path.suffix not in {".md", ".txt", ".py", ".sh", ".json"}:
            continue
        raw = path.read_bytes()
        if raw.startswith(UTF8_BOM):
            path.write_bytes(raw[3:])
            subprocess.run(["git", "add", rel], check=False)
            fixed.append(rel)
    return fixed


def main() -> int:
    # Strip BOM from staged files before any other checks.
    # Transparent fix for PowerShell Set-Content BOM injection.
    fixed = strip_bom_from_staged_files()
    if fixed:
        for f in fixed:
            print(f"  (stripped UTF-8 BOM from {f})")

    # Guard: classify branch and enforce scope.
    current_branch = run_git("rev-parse", "--abbrev-ref", "HEAD")
    branch_kind = classify_branch(current_branch)

    if branch_kind == "main":
        print(">>> ERROR: Direct commits to main are forbidden")
        print("")
        print("Create a feature branch first:")
        print("  git checkout -b feat/culture-<name>   # culture content")
        print("  git checkout -b chore/<name>          # infrastructure / tooling")
        print("  git checkout -b fix/<name>            # corrections")
        print("")
        return 1

    all_staged = run_git("diff", "--cached", "--name-only", "--diff-filter=ACMRT").splitlines()
    ok, unsafe_files = check_scope(branch_kind, all_staged)
    if not ok:
        if branch_kind == "culture":
            print(">>> ERROR: Culture branch can only modify regions/")
            print("")
            print("Unsafe files detected (split to a separate branch):")
            for f in unsafe_files:
                print(f"  x {f}")
            print("")
            print(f"  Branch:  {current_branch}")
            print( "  Allowed: regions/** + " + ", ".join(sorted(SAFE_PATTERNS)))
            print( "  Rule:    feat/culture-<name> branches contain culture content only")
            print( "  Other:   use chore/<name> or fix/<name> for infrastructure")
        else:
            print(">>> ERROR: Non-culture branch cannot modify regions/")
            print("")
            print("Culture files detected (split to a feat/culture-<name> branch):")
            for f in unsafe_files:
                print(f"  x {f}")
            print("")
            print(f"  Branch:  {current_branch}")
            print( "  Rule:    only feat/culture-<name> branches may modify regions/")
            print( "  Culture: git checkout -b feat/culture-<name>")
        print("")
        return 1

    # Run validation orchestrator (L1a → L1b → L2 → L3 → L4) on staged
    # content files only. This matches CI's scope (regions/*.md changed in
    # the diff) so legacy files in untouched paths don't block unrelated
    # commits while migrations are in flight.
    staged = run_git("diff", "--cached", "--name-only", "--diff-filter=ACMRT")
    staged_content = [
        f for f in staged.splitlines()
        if f.endswith(".md") and f.startswith("regions/")
    ]

    if staged_content:
        result = subprocess.run(
            [sys.executable, "scripts/validate.py", *staged_content],
            capture_output=True,
            text=True,
            check=False,
        )
        if result.returncode != 0:
            print(f">>> VALIDATION FAILED")
            print("")
            print(result.stdout.strip())
            print("")
            return 1

    # On culture branches: also run Hofstede validation
    # Culture content must maintain declared dimension alignment (±10 gap tolerance)
    if branch_kind == "culture":
        culture_files = [
            f for f in staged_content
            if "culture_" in f
        ]
        if culture_files:
            result = subprocess.run(
                [sys.executable, "tests/validate_hofstede_derived.py", *culture_files],
                capture_output=True,
                text=True,
                check=False,
            )
            if result.returncode != 0:
                print(f">>> HOFSTEDE VALIDATION FAILED")
                print("")
                print(result.stdout.strip())
                print("")
                return 1

    # Write validation stamp: hash of the content tree, excluding the stamp file itself
    # (removing stamp from index avoids a circular hash dependency).
    subprocess.run(["git", "rm", "--cached", "--ignore-unmatch", ".validation-stamp"],
                   capture_output=True, check=False)
    tree_hash = run_git("write-tree")
    Path(".validation-stamp").write_text(tree_hash + "\n", encoding="utf-8")
    subprocess.run(["git", "add", ".validation-stamp"], check=False)
    print(f"+ Validation stamp written ({tree_hash[:12]})")

    return 0


if __name__ == "__main__":
    sys.exit(main())
