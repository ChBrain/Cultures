# Normalize line endings and encoding for world content.
# Markdown source must be UTF-8 without BOM, LF line endings.
*.md      text eol=lf working-tree-encoding=UTF-8
*.txt     text eol=lf
*.json    text eol=lf
*.py      text eol=lf
*.sh      text eol=lf

# Binary assets (none today, but pin the convention).
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.pdf     binary
*.zip     binary
